# Azure AI Foundry project endpoint
# Example: https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# Model deployment name
AZURE_AI_MODEL_DEPLOYMENT_NAME=

# Optional: Foundry IQ / Azure AI Search endpoint for MCP + KB scripts
# Example: https://<search-service>.search.windows.net
AZURE_AI_SEARCH_SERVICE_ENDPOINT=

# Optional: Knowledge base name for MCP tool wiring in main.py
AZURE_AI_SEARCH_KNOWLEDGE_BASE_NAME=

# Optional: Project connection name in Azure AI Foundry
AZURE_AI_SEARCH_CONNECTION_NAME=
